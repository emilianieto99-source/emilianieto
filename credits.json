/* ============================================================
   DRA. LAURA MARTÍNEZ — Psicóloga
   Archetype 04 Glassmorphism Modern · Palette: Sage + Beige
   ============================================================ */

/* --- TOKENS ------------------------------------------------- */
:root {
  --bg:          #f4ede3;
  --bg-2:        #ede5d8;
  --bg-dark:     #2a3b2d;
  --glass:       rgba(255,255,255,0.52);
  --glass-2:     rgba(255,255,255,0.30);
  --glass-border:rgba(255,255,255,0.65);
  --ink:         #2a3320;
  --ink-soft:    #4a5c3e;
  --ink-mute:    #7a8e72;
  --accent:      #5c7c5f;
  --accent-2:    #a07850;
  --accent-light:#c8dbc9;
  --accent-pale: #e8f0e9;
  --warm:        #c9a87a;
  --line:        rgba(42,51,32,0.12);
  --shadow-sm:   0 2px 12px rgba(42,51,32,0.08);
  --shadow-md:   0 8px 32px rgba(42,51,32,0.12);
  --shadow-lg:   0 20px 60px rgba(42,51,32,0.16);
  --radius:      20px;
  --radius-sm:   12px;
  --ease-out:    cubic-bezier(0.22,1,0.36,1);
  --ease-in-out: cubic-bezier(0.45,0,0.55,1);
  --nav-h:       72px;
  --max-w:       1160px;
}

/* --- RESET -------------------------------------------------- */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html {
  overflow-x: clip;
  scroll-behavior: smooth;
  -webkit-text-size-adjust: 100%;
}

body {
  font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
  background: var(--bg);
  color: var(--ink);
  font-size: 1rem;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
  overflow-x: clip;
}

img { display: block; max-width: 100%; height: auto; }
a { color: inherit; text-decoration: none; }
ul, ol { list-style: none; }
button { cursor: pointer; border: none; background: none; font: inherit; }
input, textarea, select { font: inherit; }
fieldset { border: none; }

/* --- TYPOGRAPHY -------------------------------------------- */
.section-kicker {
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 0.75rem;
}

.section-title {
  font-family: "Cormorant Garamond", Georgia, serif;
  font-size: clamp(2.2rem, 5vw, 3.6rem);
  font-weight: 400;
  line-height: 1.1;
  color: var(--ink);
  text-wrap: balance;
}

.section-title em {
  font-style: italic;
  color: var(--accent);
}

.section-title--light { color: #fff; }
.section-title--light em { color: var(--accent-light); }

/* --- GLASS CARD -------------------------------------------- */
.glass-card {
  background: rgba(255,255,255,0.7);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius);
  box-shadow: var(--shadow-md);
}
@supports (backdrop-filter: blur(16px)) {
  .glass-card {
    background: var(--glass);
    backdrop-filter: blur(16px) saturate(160%);
    -webkit-backdrop-filter: blur(16px) saturate(160%);
  }
}

/* --- REVEAL ANIMATION -------------------------------------- */
.reveal {
  opacity: 0;
  transform: translateY(32px);
  transition: opacity 0.7s var(--ease-out), transform 0.7s var(--ease-out);
}
.reveal[data-split] { opacity: 1; transform: none; }
.reveal.is-visible {
  opacity: 1;
  transform: none;
}

/* --- BUTTONS ----------------------------------------------- */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.85rem 1.75rem;
  border-radius: 50px;
  font-size: 0.9rem;
  font-weight: 500;
  transition: transform 0.22s var(--ease-out), box-shadow 0.22s var(--ease-out), background 0.22s;
  white-space: nowrap;
}

.btn-primary {
  background: var(--accent);
  color: #fff;
  box-shadow: 0 4px 20px rgba(92,124,95,0.35);
}
.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 28px rgba(92,124,95,0.45);
  background: var(--ink-soft);
}

.btn-ghost {
  background: transparent;
  color: var(--ink-soft);
  border: 1.5px solid var(--line);
}
.btn-ghost:hover {
  border-color: var(--accent);
  color: var(--accent);
  transform: translateY(-2px);
}

.btn-service {
  background: transparent;
  color: var(--accent);
  border: 1.5px solid var(--accent);
  padding: 0.6rem 1.25rem;
  font-size: 0.85rem;
}
.btn-service:hover {
  background: var(--accent);
  color: #fff;
  transform: translateY(-2px);
}
.btn-service--featured {
  background: var(--accent);
  color: #fff;
}
.btn-service--featured:hover {
  background: var(--ink-soft);
  border-color: var(--ink-soft);
}

.btn-submit {
  width: 100%;
  justify-content: center;
  background: var(--accent);
  color: #fff;
  padding: 1rem 2rem;
  font-size: 1rem;
  font-weight: 500;
  border-radius: 50px;
  box-shadow: 0 4px 20px rgba(92,124,95,0.35);
  transition: transform 0.22s var(--ease-out), box-shadow 0.22s, background 0.22s, opacity 0.22s;
}
.btn-submit:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 28px rgba(92,124,95,0.45);
  background: var(--ink-soft);
}
.btn-submit.is-sending {
  opacity: 0.7;
  pointer-events: none;
}
.btn-submit-arrow {
  transition: transform 0.22s var(--ease-out);
}
.btn-submit:hover .btn-submit-arrow {
  transform: translateX(4px);
}

/* ============================================================
   NAV
   ============================================================ */
.nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  transition: background 0.4s, box-shadow 0.4s;
}
.nav.is-solid {
  background: rgba(244,237,227,0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow: 0 1px 0 var(--line);
}
.nav-inner {
  max-width: var(--max-w);
  margin: 0 auto;
  padding: 0 2rem;
  height: var(--nav-h);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
}

.nav-logo {
  display: flex;
  flex-direction: column;
  line-height: 1.2;
}
.nav-logo-name {
  font-family: "Cormorant Garamond", serif;
  font-size: 1.15rem;
  font-weight: 500;
  color: var(--ink);
}
.nav-logo-title {
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent);
}

.nav-links {
  display: flex;
  align-items: center;
  gap: 2rem;
}
.nav-link {
  font-size: 0.875rem;
  font-weight: 400;
  color: var(--ink-soft);
  position: relative;
  padding-bottom: 2px;
}
.nav-link::after {
  content: "";
  position: absolute;
  bottom: 0; left: 0;
  width: 0; height: 1px;
  background: var(--accent);
  transition: width 0.3s var(--ease-out);
}
.nav-link:hover::after { width: 100%; }
.nav-link:hover { color: var(--accent); }

.nav-cta {
  background: var(--accent);
  color: #fff;
  padding: 0.6rem 1.35rem;
  border-radius: 50px;
  font-size: 0.875rem;
  font-weight: 500;
  transition: background 0.22s, transform 0.22s;
  box-shadow: 0 2px 12px rgba(92,124,95,0.28);
}
.nav-cta:hover {
  background: var(--ink-soft);
  transform: translateY(-1px);
}

.nav-burger {
  display: none;
  flex-direction: column;
  gap: 5px;
  padding: 4px;
  width: 32px;
}
.nav-burger span {
  display: block;
  height: 1.5px;
  background: var(--ink);
  border-radius: 2px;
  transition: transform 0.3s, opacity 0.3s;
}
.nav-burger[aria-expanded="true"] span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
.nav-burger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
.nav-burger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

.nav-mobile {
  display: none;
  flex-direction: column;
  gap: 0;
  background: rgba(244,237,227,0.97);
  backdrop-filter: blur(20px);
  border-top: 1px solid var(--line);
  overflow: hidden;
  max-height: 0;
  transition: max-height 0.4s var(--ease-out);
}
.nav-mobile.is-open { max-height: 320px; }
.nav-mobile-link {
  padding: 1rem 2rem;
  font-size: 0.95rem;
  color: var(--ink-soft);
  border-bottom: 1px solid var(--line);
  transition: color 0.2s, background 0.2s;
}
.nav-mobile-link:hover { color: var(--accent); background: rgba(92,124,95,0.05); }
.nav-mobile-cta {
  color: var(--accent);
  font-weight: 500;
}

/* ============================================================
   HERO
   ============================================================ */
.hero {
  min-height: 100vh;
  min-height: 100svh;
  position: relative;
  display: flex;
  align-items: center;
  padding: calc(var(--nav-h) + 3rem) 2rem 4rem;
  overflow: clip;
}

.hero-mesh {
  position: absolute;
  inset: -10% -5%;
  z-index: 0;
  background:
    radial-gradient(at 20% 15%, #d4e8d4 0%, transparent 45%),
    radial-gradient(at 80% 20%, #f2e0c8 0%, transparent 45%),
    radial-gradient(at 50% 85%, #c8dbc9 0%, transparent 45%),
    radial-gradient(at 10% 80%, #e8d8c0 0%, transparent 40%);
  filter: blur(60px) saturate(130%);
  animation: meshFloat 20s ease-in-out infinite alternate;
}
@keyframes meshFloat {
  0%   { transform: scale(1) rotate(0deg); }
  50%  { transform: scale(1.08) rotate(3deg); }
  100% { transform: scale(1.04) rotate(-2deg); }
}

.hero-grain {
  position: absolute;
  inset: 0; z-index: 1;
  opacity: 0.035;
  pointer-events: none;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 200px;
}

.hero-content {
  position: relative; z-index: 2;
  max-width: var(--max-w);
  margin: 0 auto;
  width: 100%;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: 5rem;
}

.hero-kicker {
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 1.25rem;
}

.hero-title {
  font-family: "Cormorant Garamond", Georgia, serif;
  font-size: clamp(2.8rem, 6vw, 5rem);
  font-weight: 300;
  line-height: 1.05;
  color: var(--ink);
  margin-bottom: 1.5rem;
  text-wrap: balance;
}
.hero-title em {
  font-style: italic;
  font-weight: 400;
  color: var(--accent);
}

.hero-sub {
  font-size: 1.05rem;
  color: var(--ink-soft);
  max-width: 44ch;
  line-height: 1.7;
  margin-bottom: 2.5rem;
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  align-items: center;
}

/* Hero visual */
.hero-visual {
  position: relative;
  display: flex;
  justify-content: center;
  animation: heroFloat 6s ease-in-out infinite;
}
@keyframes heroFloat {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(-12px); }
}

.hero-img-wrap {
  position: relative;
  width: 360px;
  max-width: 100%;
}
.hero-portrait {
  width: 100%;
  height: 480px;
  object-fit: cover;
  border-radius: 200px 200px var(--radius) var(--radius);
  box-shadow: var(--shadow-lg);
  position: relative; z-index: 1;
}
.hero-img-deco {
  position: absolute;
  inset: -12px -12px -12px 12px;
  border-radius: 200px 200px var(--radius) var(--radius);
  border: 1.5px solid var(--accent-light);
  z-index: 0;
}

.hero-badge {
  position: absolute;
  bottom: 40px;
  right: -30px;
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(12px);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-sm);
  padding: 0.85rem 1.1rem;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  box-shadow: var(--shadow-sm);
  z-index: 2;
}
.hero-badge-icon { font-size: 1.25rem; color: var(--warm); }
.hero-badge-text {
  font-size: 0.8rem;
  font-weight: 500;
  color: var(--ink);
  line-height: 1.35;
}

.hero-scroll-hint {
  position: absolute;
  bottom: 2.5rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  z-index: 2;
  animation: scrollHint 2.5s ease-in-out infinite;
}
@keyframes scrollHint {
  0%, 100% { opacity: 0.5; transform: translateX(-50%) translateY(0); }
  50%       { opacity: 1;   transform: translateX(-50%) translateY(4px); }
}
.hero-scroll-line {
  width: 1px;
  height: 40px;
  background: linear-gradient(to bottom, transparent, var(--accent));
}
.hero-scroll-label {
  font-size: 0.65rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent);
}

/* ============================================================
   STRIP MARQUEE
   ============================================================ */
.strip {
  background: var(--accent);
  padding: 0.85rem 0;
  overflow: clip;
  -webkit-mask-image: linear-gradient(to right, transparent 0%, black 12%, black 88%, transparent 100%);
  mask-image: linear-gradient(to right, transparent 0%, black 12%, black 88%, transparent 100%);
}
.strip-track {
  display: flex;
  align-items: center;
  gap: 2.5rem;
  white-space: nowrap;
  animation: marquee 55s linear infinite;
  width: max-content;
}
@keyframes marquee {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}
.strip-track span {
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.9);
}
.strip-dot { color: rgba(255,255,255,0.5) !important; font-size: 0.5rem !important; }

/* ============================================================
   ABOUT
   ============================================================ */
.about {
  padding: 7rem 2rem;
  background: var(--bg);
}
.about-inner {
  max-width: var(--max-w);
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1.1fr;
  gap: 6rem;
  align-items: center;
}

/* ---- About carousel ---- */
.about-carousel {
  position: relative;
  border-radius: var(--radius);
  overflow: hidden;
  width: 100%;
}
.about-carousel-track {
  display: flex;
  transition: transform 0.55s cubic-bezier(0.4, 0, 0.2, 1);
  will-change: transform;
}
.about-carousel-slide {
  flex: 0 0 100%;
  width: 100%;
}
.about-carousel-slide img {
  width: 100%;
  height: 480px;
  object-fit: cover;
  display: block;
}

.about-carousel-slide--illus {
  height: 480px;
  display: block;
  text-align: center;
  padding: 2.5rem 1.5rem 2rem;
  overflow: hidden;
  box-sizing: border-box;
}
.about-carousel-slide--illus svg {
  display: block;
  margin: 0 auto 1.25rem;
  width: min(150px, 38vw);
  height: min(150px, 38vw);
}
.carousel-illus-label {
  font-family: "Cormorant Garamond", serif;
  font-size: clamp(1.1rem, 4vw, 1.55rem);
  font-weight: 400;
  font-style: italic;
  color: var(--ink);
  line-height: 1.25;
  margin-bottom: 0.6rem;
  display: block;
}
.carousel-illus-sub {
  font-size: clamp(0.78rem, 2.2vw, 0.84rem);
  color: var(--ink-mute);
  max-width: 30ch;
  margin: 0 auto;
  line-height: 1.65;
  display: block;
}

@media (max-width: 600px) {
  .about-carousel-slide--illus {
    height: auto;
    min-height: 340px;
    padding: 2rem 1.25rem;
  }
}
.about-carousel-btn {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(255,255,255,0.85);
  border: none;
  border-radius: 50%;
  width: 40px; height: 40px;
  font-size: 1.1rem;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 2px 12px rgba(0,0,0,0.12);
  transition: background 0.2s, opacity 0.2s;
  z-index: 2;
  opacity: 0.8;
}
.about-carousel-btn:hover { background: #fff; opacity: 1; }
.about-carousel-btn--prev { left: 12px; }
.about-carousel-btn--next { right: 12px; }
.about-carousel-dots {
  position: absolute;
  bottom: 12px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 6px;
  z-index: 2;
}
.about-carousel-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: rgba(255,255,255,0.5);
  cursor: pointer;
  transition: background 0.25s, transform 0.25s;
}
.about-carousel-dot.is-active {
  background: #fff;
  transform: scale(1.3);
}

.about-img-col { position: relative; }
.about-img-frame {
  position: relative;
  border-radius: var(--radius);
  overflow: clip;
}
.about-img-frame img {
  width: 100%;
  height: 520px;
  object-fit: cover;
  display: block;
  transition: transform 0.6s var(--ease-out);
}
.about-img-frame:hover img { transform: scale(1.04); }
.about-img-accent {
  position: absolute;
  top: -16px; right: -16px;
  width: 120px; height: 120px;
  border-radius: 50%;
  background: var(--accent-light);
  z-index: -1;
  opacity: 0.6;
}

.about-quote-card {
  position: absolute;
  bottom: -24px;
  right: -32px;
  padding: 1.25rem 1.5rem;
  max-width: 260px;
  z-index: 2;
}
.about-quote-text {
  font-family: "Cormorant Garamond", serif;
  font-style: italic;
  font-size: 1rem;
  color: var(--ink);
  line-height: 1.55;
}

.about-text-col { display: flex; flex-direction: column; gap: 0; }
.about-para {
  color: var(--ink-soft);
  line-height: 1.8;
  margin-bottom: 1.25rem;
  font-size: 1rem;
}

.about-credentials {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
  margin-top: 1.5rem;
}
.about-credentials .credential-item:last-child:nth-child(odd) {
  grid-column: 1 / -1;
}
.credential-item {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  padding: 1rem;
  background: var(--accent-pale);
  border-radius: var(--radius-sm);
  border: 1px solid var(--accent-light);
}
.credential-icon { font-size: 1.1rem; margin-top: 2px; flex-shrink: 0; }
.credential-item strong {
  display: block;
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 0.15rem;
}
.credential-item span {
  font-size: 0.76rem;
  color: var(--ink-mute);
}

/* ============================================================
   SERVICES
   ============================================================ */
.services {
  padding: 7rem 2rem;
  background: var(--bg-2);
}
.services-inner { max-width: var(--max-w); margin: 0 auto; }
.services-header {
  text-align: center;
  margin-bottom: 4rem;
}
.services-sub {
  max-width: 52ch;
  margin: 1.25rem auto 0;
  color: var(--ink-soft);
  line-height: 1.7;
}

.services-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  align-items: start;
}

.service-card {
  padding: 2.5rem;
  display: flex;
  flex-direction: column;
  gap: 0;
  transition: transform 0.3s var(--ease-out), box-shadow 0.3s;
  position: relative;
  overflow: clip;
}
.service-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-lg);
}
.service-card--featured {
  background: rgba(92,124,95,0.08);
  border-color: var(--accent-light);
}
@supports (backdrop-filter: blur(16px)) {
  .service-card--featured {
    background: rgba(92,124,95,0.12);
  }
}

.service-tag {
  display: inline-flex;
  align-items: center;
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent);
  background: var(--accent-pale);
  border: 1px solid var(--accent-light);
  border-radius: 50px;
  padding: 0.3rem 0.85rem;
  margin-bottom: 1.5rem;
  width: fit-content;
}
.service-tag--featured {
  background: var(--accent);
  color: #fff;
  border-color: var(--accent);
}

.service-icon-wrap {
  margin-bottom: 1.25rem;
}

.service-name {
  font-family: "Cormorant Garamond", serif;
  font-size: 1.9rem;
  font-weight: 400;
  color: var(--ink);
  margin-bottom: 0.25rem;
}
.service-duration {
  font-size: 0.8rem;
  color: var(--accent);
  font-weight: 500;
  letter-spacing: 0.06em;
  margin-bottom: 1.25rem;
}
.service-desc {
  font-size: 0.92rem;
  color: var(--ink-soft);
  line-height: 1.75;
  margin-bottom: 1.5rem;
}

.service-includes {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
  margin-bottom: 2rem;
}
.service-includes li {
  font-size: 0.85rem;
  color: var(--ink-soft);
  padding-left: 1.25rem;
  position: relative;
}
.service-includes li::before {
  content: "✓";
  position: absolute;
  left: 0;
  color: var(--accent);
  font-size: 0.75rem;
  font-weight: 600;
}

.service-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
  padding-top: 1.5rem;
  border-top: 1px solid var(--line);
}
.service-price {
  font-family: "Cormorant Garamond", serif;
  font-size: 2rem;
  font-weight: 400;
  color: var(--ink);
}

/* ============================================================
   STATS
   ============================================================ */
.stats {
  padding: 5rem 2rem;
  background: var(--bg-dark);
}
.stats-inner {
  max-width: var(--max-w);
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  flex-wrap: wrap;
}

.stat-item {
  text-align: center;
  padding: 2rem 3.5rem;
  flex: 1;
  min-width: 180px;
}
.stat-num {
  font-family: "Cormorant Garamond", serif;
  font-size: clamp(3rem, 5vw, 4.5rem);
  font-weight: 300;
  color: var(--accent-light);
  line-height: 1;
  display: inline;
}
.stat-plus {
  font-family: "Cormorant Garamond", serif;
  font-size: clamp(2rem, 3vw, 3rem);
  font-weight: 300;
  color: var(--accent);
  line-height: 1;
}
.stat-label {
  font-size: 0.8rem;
  color: rgba(200,219,201,0.6);
  margin-top: 0.5rem;
  letter-spacing: 0.04em;
}
.stat-divider {
  width: 1px;
  height: 60px;
  background: rgba(200,219,201,0.2);
}

/* ============================================================
   TESTIMONIALS
   ============================================================ */
.testimonials {
  padding: 7rem 2rem;
  background: var(--bg);
}
.testimonials-inner {
  max-width: var(--max-w);
  margin: 0 auto;
}
.testimonials-inner > .section-kicker,
.testimonials-inner > .section-title {
  text-align: center;
  margin-bottom: 1rem;
}
.testimonials-inner > .section-title { margin-bottom: 3.5rem; }

.testimonials-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.75rem;
}

.testimonial-card {
  padding: 2rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  transition: transform 0.3s var(--ease-out);
}
.testimonial-card:hover { transform: translateY(-4px); }

.testimonial-stars { color: var(--warm); font-size: 0.9rem; letter-spacing: 2px; }

.testimonial-quote {
  font-family: "Cormorant Garamond", serif;
  font-style: italic;
  font-size: 1.05rem;
  color: var(--ink-soft);
  line-height: 1.65;
  flex: 1;
}

.testimonial-author {
  display: flex;
  align-items: center;
  gap: 0.85rem;
  padding-top: 1rem;
  border-top: 1px solid var(--line);
}
.testimonial-avatar {
  width: 40px; height: 40px;
  border-radius: 50%;
  background: var(--accent);
  color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-family: "Cormorant Garamond", serif;
  font-size: 1.1rem;
  font-weight: 500;
  flex-shrink: 0;
}
.testimonial-author strong {
  display: block;
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--ink);
}
.testimonial-author span {
  font-size: 0.75rem;
  color: var(--ink-mute);
}

/* ============================================================
   BOOKING
   ============================================================ */
.booking {
  padding: 7rem 2rem;
  background: var(--bg-dark);
  position: relative;
  overflow: clip;
}
.booking-mesh {
  position: absolute;
  inset: 0; z-index: 0;
  background:
    radial-gradient(at 80% 20%, rgba(92,124,95,0.25) 0%, transparent 50%),
    radial-gradient(at 20% 80%, rgba(160,120,80,0.18) 0%, transparent 50%);
  filter: blur(80px);
}
.booking-inner {
  position: relative; z-index: 1;
  max-width: var(--max-w);
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1.5fr;
  gap: 5rem;
  align-items: start;
}
.booking-inner--calendly {
  grid-template-columns: 1fr;
  max-width: 900px;
}
.booking-calendly-wrap {
  grid-column: 1 / -1;
  border-radius: var(--radius);
  overflow: visible;
  background: #fff;
}

.booking-header { grid-column: 1 / -1; text-align: center; max-width: 56ch; margin: 0 auto; }
.booking-sub {
  color: rgba(200,219,201,0.7);
  margin-top: 1.25rem;
  line-height: 1.7;
}

.booking-form-wrap {
  padding: 2.5rem;
  background: rgba(255,255,255,0.06) !important;
  border-color: rgba(255,255,255,0.12) !important;
  grid-column: 1 / -1;
}
@supports (backdrop-filter: blur(16px)) {
  .booking-form-wrap {
    background: rgba(255,255,255,0.06) !important;
  }
}

/* Session selector */
.form-legend {
  font-size: 0.82rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(200,219,201,0.7);
  margin-bottom: 1rem;
  display: block;
}
.session-selector {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
  margin-bottom: 2rem;
}
.session-opt {
  cursor: pointer;
  display: flex;
  align-items: flex-start;
  gap: 0;
}
.session-opt input[type="radio"] {
  display: none;
}
.session-opt-content {
  width: 100%;
  padding: 1.25rem 1.5rem;
  border: 1.5px solid rgba(255,255,255,0.15);
  border-radius: var(--radius-sm);
  background: rgba(255,255,255,0.05);
  transition: border-color 0.2s, background 0.2s;
  cursor: pointer;
}
.session-opt input:checked ~ .session-opt-content {
  border-color: var(--accent);
  background: rgba(92,124,95,0.18);
}
.session-opt:hover .session-opt-content {
  border-color: rgba(200,219,201,0.4);
  background: rgba(255,255,255,0.08);
}
.session-opt-name {
  display: block;
  font-size: 1rem;
  font-weight: 600;
  color: #fff;
  margin-bottom: 0.2rem;
}
.session-opt-detail {
  display: block;
  font-size: 0.8rem;
  color: var(--accent-light);
  margin-bottom: 0.4rem;
}
.session-opt-desc {
  display: block;
  font-size: 0.78rem;
  color: rgba(200,219,201,0.6);
  line-height: 1.4;
}

/* Form fields */
.form-fieldset { border: none; margin-bottom: 0; }
.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.25rem;
  margin-bottom: 1.25rem;
}
.form-group { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.25rem; }
.form-group:last-of-type { margin-bottom: 0; }

.form-label {
  font-size: 0.8rem;
  font-weight: 500;
  color: rgba(200,219,201,0.8);
  letter-spacing: 0.04em;
}
.form-optional { color: rgba(200,219,201,0.45); font-weight: 400; }

.form-input {
  background: rgba(255,255,255,0.07);
  border: 1.5px solid rgba(255,255,255,0.15);
  border-radius: var(--radius-sm);
  padding: 0.85rem 1.1rem;
  color: #fff;
  font-size: 0.9rem;
  transition: border-color 0.2s, background 0.2s;
  outline: none;
  -webkit-appearance: none;
}
.form-input::placeholder { color: rgba(200,219,201,0.35); }
.form-input:focus {
  border-color: var(--accent);
  background: rgba(255,255,255,0.1);
}
.form-input:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
input[type="date"].form-input::-webkit-calendar-picker-indicator {
  filter: invert(0.7);
  cursor: pointer;
}

.form-textarea {
  resize: vertical;
  min-height: 110px;
}

.form-privacy {
  margin: 1.5rem 0 1.75rem;
}
.privacy-label {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  cursor: pointer;
}
.privacy-label input[type="checkbox"] {
  width: 16px; height: 16px;
  accent-color: var(--accent);
  margin-top: 3px;
  flex-shrink: 0;
}
.privacy-label span {
  font-size: 0.8rem;
  color: rgba(200,219,201,0.6);
  line-height: 1.5;
}
.form-link { color: var(--accent-light); text-decoration: underline; }

.form-note {
  margin-top: 1rem;
  font-size: 0.75rem;
  color: rgba(200,219,201,0.4);
  text-align: center;
  line-height: 1.5;
}

/* Success state */
.booking-success {
  text-align: center;
  padding: 3rem 2rem;
}
.success-icon {
  margin: 0 auto 1.5rem;
  width: 60px; height: 60px;
}
.success-check {
  stroke-dasharray: 40;
  stroke-dashoffset: 40;
  animation: checkDraw 0.6s 0.3s var(--ease-out) forwards;
}
@keyframes checkDraw { to { stroke-dashoffset: 0; } }
.success-title {
  font-family: "Cormorant Garamond", serif;
  font-size: 2rem;
  font-weight: 400;
  color: #fff;
  margin-bottom: 0.75rem;
}
.success-text {
  color: rgba(200,219,201,0.7);
  margin-bottom: 2rem;
  max-width: 44ch;
  margin-inline: auto;
  line-height: 1.7;
}

/* Contact aside */
.booking-contact {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  grid-column: 1 / 2;
  grid-row: 3;
  display: none;
}
.contact-item {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
}
.contact-icon { font-size: 1.2rem; margin-top: 2px; }
.contact-item strong {
  display: block;
  font-size: 0.8rem;
  font-weight: 600;
  color: rgba(200,219,201,0.7);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin-bottom: 0.2rem;
}
.contact-item span,
.contact-item a {
  font-size: 0.9rem;
  color: rgba(200,219,201,0.9);
  line-height: 1.4;
}
.contact-item a:hover { color: var(--accent-light); text-decoration: underline; }

/* ============================================================
   FOOTER
   ============================================================ */
.footer {
  background: var(--ink);
  padding: 2.5rem 2rem;
}
.footer-inner {
  max-width: var(--max-w);
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
  flex-wrap: wrap;
}
.footer-brand {
  display: flex;
  flex-direction: column;
}
.footer-name {
  font-family: "Cormorant Garamond", serif;
  font-size: 1.1rem;
  color: rgba(255,255,255,0.9);
  font-weight: 400;
}
.footer-tagline {
  font-size: 0.7rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.4);
  margin-top: 0.2rem;
}
.footer-nav {
  display: flex;
  gap: 2rem;
  flex-wrap: wrap;
}
.footer-nav a {
  font-size: 0.82rem;
  color: rgba(255,255,255,0.5);
  transition: color 0.2s;
}
.footer-nav a:hover { color: var(--accent-light); }
.footer-legal {
  font-size: 0.72rem;
  color: rgba(255,255,255,0.3);
  width: 100%;
  text-align: center;
  padding-top: 1.5rem;
  border-top: 1px solid rgba(255,255,255,0.08);
}

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (max-width: 1023px) {
  .hero-content { gap: 3rem; }
  .about-inner { gap: 3.5rem; }
  .booking-inner { gap: 3rem; }
  .testimonials-grid { gap: 1.25rem; }
}

@media (max-width: 900px) {
  .nav-links { display: none; }
  .nav-burger { display: flex; }
  .nav-mobile { display: flex; }

  .hero-content {
    grid-template-columns: 1fr;
    text-align: center;
  }
  .hero-text { order: 1; }
  .hero-visual { order: 2; }
  .hero-actions { justify-content: center; }
  .hero-sub { margin-inline: auto; }
  .hero-scroll-hint { display: none; }
  .hero-img-wrap { width: 260px; }
  .hero-portrait { height: 340px; }
  .hero-badge { right: -10px; bottom: 20px; }

  .about-inner { grid-template-columns: 1fr; }
  .about-quote-card { position: static; margin-top: 1.5rem; }
  .about-img-accent { display: none; }

  .services-grid { grid-template-columns: 1fr; max-width: 540px; margin-inline: auto; }

  .stats-inner { gap: 0; }
  .stat-divider { display: none; }
  .stat-item { min-width: 50%; padding: 1.5rem 1rem; }

  .testimonials-grid { grid-template-columns: 1fr; max-width: 540px; margin-inline: auto; }

  .booking-inner { grid-template-columns: 1fr; gap: 3rem; }
  .booking-header { grid-column: 1; }
  .booking-form-wrap { grid-column: 1; }

  .footer-inner { flex-direction: column; align-items: flex-start; gap: 1.5rem; }
}

@media (max-width: 600px) {
  .about { padding: 5rem 1.5rem; }
  .services { padding: 5rem 1.5rem; }
  .testimonials { padding: 5rem 1.5rem; }
  .booking { padding: 5rem 1.5rem; }

  .form-row { grid-template-columns: 1fr; }
  .session-selector { grid-template-columns: 1fr; }
  .booking-form-wrap { padding: 1.75rem; }

  .about-credentials { grid-template-columns: 1fr; }

  .stat-item { min-width: 100%; }

  .hero-title { font-size: clamp(2.2rem, 8vw, 3rem); }
}

/* ============================================================
   ACCESSIBILITY / REDUCED MOTION
   Only gates truly intrusive effects
   ============================================================ */
@media (prefers-reduced-motion: reduce) {
  .hero-mesh { animation: none; }
  .hero-visual { animation: none; }
  .hero-scroll-hint { animation: none; }
  .strip-track { animation: none; }
}
